API_PORT=8787
# Si el host inyecta PORT automáticamente, server.js lo prioriza sobre API_PORT.
NODE_ENV=development

FRONTEND_ORIGIN=http://localhost:5173
# Producción (separar con coma si hay varios orígenes):
# FRONTEND_ORIGIN=https://artesaniasani.neocities.org

# --- SEGURIDAD: cambiar ambos valores antes de desplegar ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIAR_PASSWORD_SEGURA
# Genera una contraseña segura: openssl rand -base64 16
# Si contiene #, espacios u otros caracteres especiales, envuélvela en comillas:
# ADMIN_PASSWORD="MiPassword#Segura2026!"

# JWT_SECRET debe tener al menos 32 caracteres. Genera con: openssl rand -base64 32
JWT_SECRET=CAMBIAR_POR_SECRETO_LARGO_Y_ALEATORIO_DE_MINIMO_32_CARACTERES

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
# SSL: algunos proveedores PostgreSQL usan certificados propios → DB_SSL_REJECT_UNAUTHORIZED=false (default).
# Si tu proveedor tiene un certificado CA verificable, usa DB_SSL_REJECT_UNAUTHORIZED=true.
DB_SSL_REJECT_UNAUTHORIZED=false

JWT_EXPIRES_IN=8h
# Frontend y API en dominios distintos: COOKIE_SAME_SITE=none y COOKIE_SECURE=true
# Mismo host (local): COOKIE_SAME_SITE=lax y COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_MAX_ATTEMPTS=8
AUTH_LOCK_WINDOW_MINUTES=30
AUTH_LOCK_MAX_FAILURES=5
AUTH_LOCK_DURATION_MINUTES=30

PYTHON_BIN=python3
PRODUCT_IMAGES_DIR=public/images
# Si frontend y API están en dominios distintos define la base pública:
# PRODUCT_IMAGES_PUBLIC_BASE_URL=https://artesaniasani.neocities.org
IMAGE_MAX_SIZE=1024
IMAGE_QUALITY=82
IMAGE_SOFT_BLOCK_MB=5
IMAGE_UPLOAD_MAX_MB=12
